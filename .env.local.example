# Copy this file to .env.local and fill in the values

# Medusa backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.luxus-collection.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...

# Site URL (change to dev.luxus-collection.com for the dev deployment)
NEXT_PUBLIC_SITE_URL=https://dev.luxus-collection.com

# Meilisearch
NEXT_PUBLIC_MEILI_URL=https://search.luxus-collection.com
NEXT_PUBLIC_MEILI_SEARCH_KEY=your-search-only-key
